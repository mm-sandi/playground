# Copy this file to .env and fill in your Slack tokens.
# Do NOT commit .env to version control.

# Bot User OAuth Token (starts with xoxb-)
# Find it: api.slack.com/apps → Your App → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token (starts with xapp-)
# Required for Socket Mode. Create at: api.slack.com/apps → Your App → Basic Information → App-Level Tokens
# Scopes needed: connections:write
SLACK_APP_TOKEN=xapp-your-app-token-here
